# StarForge Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Google AI Studio API Key (for Gemini 2.5 Flash via ADK)
# Get yours free at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# NASA API Key (optional - demo key works for low traffic)
# Get yours free at: https://api.nasa.gov
NASA_API_KEY=DEMO_KEY
