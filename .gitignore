# ==========================================
# SECURITY — Never commit secrets or keys!
# ==========================================
.env
.env.*
!.env.example
*.key
*.pem
*.secret
*.credentials

# ==========================================
# Virtual environment
# ==========================================
.venv/
venv/
env/

# ==========================================
# Python cache & bytecode
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# Distribution & build artifacts
# ==========================================
dist/
build/
*.egg-info/
*.egg

# ==========================================
# IDE & editor files
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ==========================================
# OS-generated files
# ==========================================
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# Local user data & sessions (runtime)
# ==========================================
.starforge/
*.db
*.sqlite
*.sqlite3
sessions.db

# ==========================================
# Test artifacts
# ==========================================
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ==========================================
# Miscellaneous
# ==========================================
*.log
*.bak
*.tmp
